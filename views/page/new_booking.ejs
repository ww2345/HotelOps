<% layout("layout/boilerplate_admin.ejs") -%>

  <div class="page-shell admin-shell">
    <section class="py-4 admin-hero" id="new-booking">
      <div
        class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
          <p class="text-muted mb-1">Admin</p>
          <h1 class="h3 mb-0">New Booking</h1>
          <div class="text-muted small mt-1">Enter guest details to create a booking.</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-outline-dark btn-sm" href="/admin/bookings">
            <i class="fa-solid fa-arrow-left me-2"></i>Back to bookings
          </a>
          <a class="btn btn-dark btn-sm" href="/admin">
            <i class="fa-solid fa-gauge-high me-2"></i>Dashboard
          </a>
        </div>
      </div>

      <div class="admin-panel">
        <div class="p-3 p-md-4">
          <form class="row g-3" action="/admin/booking/new_booking" method="post">
            <div class="col-12 col-lg-6">
              <label for="bookingName" class="form-label fw-semibold">Name</label>
              <input type="text" class="form-control" id="bookingName" aria-describedby="emailHelp"
                placeholder="Guest name" name="name" required>
            </div>

            <div class="col-12 col-lg-6">
              <label for="bookingContact" class="form-label fw-semibold">Contact</label>
              <input type="tel" class="form-control" id="bookingContact" placeholder="Contact number" name="contactno"
                inputmode="numeric" pattern="[0-9]+" required>
            </div>

            <div class="col-12">
              <label for="bookingCheckin" class="form-label fw-semibold">Check-in Time</label>
              <input type="time" class="form-control" id="bookingCheckin" name="checkin" step="60" required>
            </div>

            <div class="col-12">
              <label for="bookingCheckin" class="form-label fw-semibold">Check-out Time</label>
              <input type="time" class="form-control" id="bookingCheckout" name="checkin" step="60" required>
            </div>

            <div class="col-12 d-flex flex-column flex-sm-row gap-2 justify-content-end pt-2">
              <a class="btn btn-outline-dark" href="/admin/bookings">Cancel</a>
              <button type="submit" class="btn btn-dark">
                <i class="fa-solid fa-circle-check me-2"></i>Create booking
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>