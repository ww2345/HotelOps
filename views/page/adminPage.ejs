<% layout("layout/boilerplate") -%>

  <div class="page-shell admin-shell">
    <section class="py-4 admin-hero" id="dashboard">
      <div
        class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
          <p class="text-muted mb-1">Admin dashboard</p>
          <h1 class="h3 mb-0">HotelOps Control Center</h1>
          <% if (typeof adminUser==="string" && adminUser) { %>
            <div class="text-muted small mt-1">Signed in as <strong>
                <%= adminUser %>
              </strong></div>
            <% } %>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <a class="btn btn-outline-dark btn-sm" href="/"><i class="fa-regular fa-house"></i> Home</a>
          <a class="btn btn-outline-dark btn-sm" href="/contact"><i class="fa-solid fa-headset me-2"></i>Support</a>

        </div>
      </div>

      <div class="row g-3 admin-kpis">
        <div class="col-12 col-md-6 col-lg-3">
          <div class="admin-kpi">
            <div class="admin-kpi-icon"><i class="fa-solid fa-bed"></i></div>
            <div>
              <div class="admin-kpi-label">Total rooms</div>
              <div class="admin-kpi-value">
                <%= stats?.totalRooms ?? 0 %>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
          <div class="admin-kpi">
            <div class="admin-kpi-icon admin-kpi-icon-danger"><i class="fa-solid fa-door-closed"></i></div>
            <div>
              <div class="admin-kpi-label">Booked rooms</div>
              <div class="admin-kpi-value">
                <%= stats?.occupiedRooms ?? 0 %>
              </div>
              <div class="admin-kpi-sub">Occupancy <%= stats?.occupancyPct ?? 0 %>%</div>
            </div>
          </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
          <div class="admin-kpi">
            <div class="admin-kpi-icon admin-kpi-icon-success"><i class="fa-solid fa-door-open"></i></div>
            <div>
              <div class="admin-kpi-label">Available</div>
              <div class="admin-kpi-value">
                <%= stats?.availableRooms ?? 0 %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-4 admin-section" id="rooms">
      <div class="admin-section-head">
        <div>
          <p class="text-muted mb-1">Database</p>
          <h2 class="h4 mb-0">Rooms</h2>
        </div>
      </div>

      <div class="admin-panel">
        <div class="p-3 p-md-4">
          <% const formatINR=(value)=>{ try { return new Intl.NumberFormat("en-IN",{style:"currency",currency:"INR",maximumFractionDigits:0}).format(value); } catch(e) { return `₹${value}`; } }; %>

          <% if (Array.isArray(rooms) && rooms.length) { %>
            <div class="row g-3">
              <% for (const r of rooms) { %>
                <% const roomNo=r?.room ?? "-"; %>
                <% const s=String(r?.status ?? "" ).trim(); %>
                <% const sKey=s.toLowerCase(); %>
                <% const priceNum=Number(r?.price); %>
                <% const priceLabel=Number.isFinite(priceNum) ? formatINR(priceNum) : "-"; %>

                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                  <div class="admin-room-card h-100">
                    <div class="d-flex align-items-start justify-content-between gap-3">
                      <div>
                        <div class="text-muted small">Room</div>
                        <div class="admin-room-number"><%= roomNo %></div>
                      </div>
                      <div class="text-end">
                        <% if (!s) { %>
                          <span class="text-muted">-</span>
                        <% } else if (sKey==="available" ) { %>
                          <span class="badge text-bg-success"><%= s %></span>
                        <% } else if (sKey==="occupied" ) { %>
                          <span class="badge text-bg-danger"><%= s %></span>
                        <% } else { %>
                          <span class="badge text-bg-secondary"><%= s %></span>
                        <% } %>
                      </div>
                    </div>

                    <div class="admin-room-meta">
                      <div>
                        <div class="text-muted small">Price</div>
                        <div class="admin-room-price"><%= priceLabel %></div>
                      </div>
                      <div class="admin-room-icon text-muted"><i class="fa-solid fa-tag"></i></div>
                    </div>
                  </div>
                </div>
              <% } %>
            </div>
          <% } else { %>
            <div class="admin-empty">
              <div class="admin-empty-icon"><i class="fa-regular fa-folder-open"></i></div>
              <div>
                <div class="fw-semibold">No rooms yet</div>
                <div class="text-muted small">Rooms added in MongoDB will appear here.</div>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </section>
  </div>
